#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    vector<int> maxMeetings(vector<int>& start, vector<int>& end) {

        
        vector<tuple<int,int,int>> meetings;

        
        for (int i = 0; i < start.size(); i++) {
            meetings.push_back({end[i], start[i], i + 1});
        }

        
        sort(meetings.begin(), meetings.end());

        vector<int> result;

        
        int lastEnd = -1;


        
        for (int i = 0; i < meetings.size(); i++) {

            int e = get<0>(meetings[i]);    // end time
            int s = get<1>(meetings[i]);    // start time
            int idx = get<2>(meetings[i]);  // meeting number


            
            if (s > lastEnd) {

                
                result.push_back(idx);

               
                lastEnd = e;
            }
        }

        return result;
    }
};


int main() {

    vector<int> start = {1, 3, 0, 5, 8, 5};
    vector<int> end   = {2, 4, 6, 7, 9, 9};


    Solution sol;

    vector<int> ans = sol.maxMeetings(start, end);


    cout << "Selected meetings: ";

    for (int i = 0; i < ans.size(); i++) {
        cout << ans[i] << " ";
    }

    return 0;
}
