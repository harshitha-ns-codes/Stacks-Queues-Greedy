#include<bits/stdc++.h>
using namespace std;

struct Item
{
    int value;
    int weight;
}

static bool compare(Item a , Item b)
{
    double r1 = (double) a.value / (double) a.weight;
    double r2 = (double) b.value / (double) b.weight;
    return r1>r2;
};

double fractionalKnapsack(int wt , Item arr[] , int N)
{
    sort(arr , arr+N , compare);
    int curWt =0;
    double finalVal=0;

    for(int i=0;i<N;i++)
    {
        if(curWt + arr[i].weight <= wt)
        {
            curWt += arr[i].weight;
            finalVal += arr[i].value;
        }
        else
        {
            int remaining = wt - curWt;
            finalVal += ( arr[i].value /(double) arr[i].weight) * remaining;
            break;
        }
    }
    return finalVal;
}
