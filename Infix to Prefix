#include <bits/stdc++.h>
using namespace std;

class Solution
{
public:

    int priority(char ch)
    {
        if(ch == '^')
            return 3;

        else if(ch == '*' || ch == '/')
            return 2;

        else if(ch == '+' || ch == '-')
            return 1;

        return -1;
    }

    // Reverse string
    string reverseString(string s)
    {
        int i = 0;
        int j = s.length() - 1;

        while(i < j)
        {
            swap(s[i], s[j]);
            i++;
            j--;
        }

        return s;
    }

    string infixToPrefix(string s)
    {
        // Step 1: Reverse infix expression
        s = reverseString(s);

        // Step 2: Change brackets
        for(int i = 0; i < s.length(); i++)
        {
            if(s[i] == '(')
                s[i] = ')';

            else if(s[i] == ')')
                s[i] = '(';
        }

        stack<char> st;
        string ans = "";

        // Step 3: Infix to Postfix
        for(int i = 0; i < s.length(); i++)
        {
            // Operand
            if((s[i] >= 'A' && s[i] <= 'Z') ||
               (s[i] >= 'a' && s[i] <= 'z') ||
               (s[i] >= '0' && s[i] <= '9'))
            {
                ans += s[i];
            }

            // Opening bracket
            else if(s[i] == '(')
            {
                st.push(s[i]);
            }

            // Closing bracket
            else if(s[i] == ')')
            {
                while(!st.empty() && st.top() != '(')
                {
                    ans += st.top();
                    st.pop();
                }

                if(!st.empty())
                    st.pop();
            }

            // Operator
            else
            {
                if(s[i] == '^')
                {
                    while(!st.empty() &&
                          priority(s[i]) <= priority(st.top()))
                    {
                        ans += st.top();
                        st.pop();
                    }
                }

                else
                {
                    while(!st.empty() &&
                          priority(s[i]) < priority(st.top()))
                    {
                        ans += st.top();
                        st.pop();
                    }
                }

                st.push(s[i]);
            }
        }

        // Remaining operators
        while(!st.empty())
        {
            ans += st.top();
            st.pop();
        }

        // Step 4: Reverse postfix to get prefix
        ans = reverseString(ans);

        return ans;
    }
};

int main()
{
    Solution obj;

    string s = "(A-B/C)*(A/K-L)";

    cout << obj.infixToPrefix(s);

    return 0;
}
